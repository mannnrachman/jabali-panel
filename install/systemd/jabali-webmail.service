[Unit]
Description=Jabali Webmail (Bulwark, Next.js)
Documentation=https://github.com/bulwarkmail/webmail
After=network-online.target jabali-stalwart.service
Wants=network-online.target
PartOf=jabali.slice

[Service]
Type=simple
User=jabali-webmail
# M25 Step 5: jabali-sockets so the listen socket inside
# /run/jabali-bulwark/ is reachable by nginx (also a jabali-sockets
# member). User= stays jabali-webmail; only Group= flips.
Group=jabali-sockets
Slice=jabali.slice

WorkingDirectory=/opt/jabali-webmail
# M25 Step 5: the stock Bulwark server.js binds TCP HOSTNAME:PORT and
# can't be reconfigured to a Unix socket without modifying generated
# Next.js code. We ship a thin wrapper at /opt/jabali-webmail/server-unix.js
# (~30 lines) that imports the same Next.js handler and listens on
# SOCKET_PATH. systemd executes the wrapper instead of server.js;
# bulwark updates that overwrite server.js leave server-unix.js alone.
Environment=SOCKET_PATH=/run/jabali-bulwark/bulwark.sock
Environment=NODE_ENV=production
# Ensure .next/cache exists before main process starts. The Bulwark
# tarball doesn't ship the cache subdir; without it, systemd refuses
# to enter mount namespacing (ReadWritePaths below references the
# path) and the unit fails with status=226/NAMESPACE. The leading +
# runs the command as root so the directory can be created even when
# /opt/jabali-webmail is owned by jabali-webmail:jabali-webmail and
# the user-mode process couldn't mkdir at the required time.
ExecStartPre=+/bin/mkdir -p /opt/jabali-webmail/.next/cache
ExecStartPre=+/bin/chown jabali-webmail:jabali-webmail /opt/jabali-webmail/.next/cache
ExecStart=/usr/bin/node /opt/jabali-webmail/server-unix.js

# RuntimeDirectory creates /run/jabali-bulwark on every start, owned
# jabali-webmail:jabali-sockets 0750. The wrapper drops the socket
# file inside and chmods it 0660 after net.Server.listen() returns.
RuntimeDirectory=jabali-bulwark
RuntimeDirectoryMode=0750
RuntimeDirectoryPreserve=no

# bulwark.env is provisioned in Step 8 of the M6 plan. Optional at
# install time so the unit survives `install -> systemctl enable` runs
# before Step 8 has created it; runtime settings (JMAP_SERVER_URL etc.)
# land there.
EnvironmentFile=-/etc/jabali-panel/bulwark.env

# Bulwark must always be running while enabled. Restart=on-failure left
# the unit "inactive" after clean exits — observed when the stock
# update-check phase (logged "Update available: v1.5.2") finishes and
# nothing else keeps the event loop alive on certain Bulwark builds, or
# when systemd's namespace setup tears the process down post-listen.
# Restart=always recovers from both the on-failure cases AND any clean
# exit, which is the only correct policy for a long-lived HTTP daemon.
Restart=always
RestartSec=5s

# Security hardening.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/jabali-webmail /opt/jabali-webmail/.next/cache /run/jabali-bulwark

StandardOutput=journal
StandardError=journal

[Install]
# Intentionally NOT enabled — see jabali-stalwart.service.
WantedBy=multi-user.target
