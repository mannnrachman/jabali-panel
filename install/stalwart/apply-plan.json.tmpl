[
  {
    "@type": "create",
    "object": "x:Directory",
    "value": {
      "#sql-directory": {
        "@type": "Sql",
        "description": "Jabali panel mailboxes (authoritative; see ADR-0042)",
        "store": {
          "@type": "MySql",
          "host": "127.0.0.1",
          "port": 3306,
          "database": "jabali_panel",
          "authUsername": "jabali-stalwart-ro",
          "authSecret": {
            "@type": "Value",
            "secret": "{{.MariaDBPassword}}"
          },
          "useTls": false,
          "allowInvalidCerts": false
        },
        "columnEmail": "email_cached",
        "columnSecret": "password_hash",
        "columnClass": null,
        "columnDescription": null,
        "queryLogin": "SELECT email_cached, password_hash FROM mailboxes WHERE email_cached = ? AND is_disabled = 0",
        "queryRecipient": "SELECT email_cached, password_hash FROM mailboxes WHERE email_cached = ? AND is_disabled = 0",
        "queryMemberOf": null,
        "queryEmailAliases": null
      }
    }
  },

  {
    "@type": "update",
    "object": "x:Authentication",
    "id": "singleton",
    "value": {
      "directoryId": "#sql-directory",
      "passwordHashAlgorithm": "bcrypt"
    }
  },

  {
    "@type": "create",
    "object": "x:NetworkListener",
    "value": {
      "#smtp-25": {
        "name": "smtp-25",
        "bind": {"0.0.0.0:25": true},
        "protocol": "smtp",
        "useTls": false,
        "tlsImplicit": false,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      },
      "#smtp-submissions-465": {
        "name": "smtp-submissions-465",
        "bind": {"0.0.0.0:465": true},
        "protocol": "smtp",
        "useTls": true,
        "tlsImplicit": true,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      },
      "#smtp-submission-587": {
        "name": "smtp-submission-587",
        "bind": {"0.0.0.0:587": true},
        "protocol": "smtp",
        "useTls": true,
        "tlsImplicit": false,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      },
      "#imap-993": {
        "name": "imap-993",
        "bind": {"0.0.0.0:993": true},
        "protocol": "imap",
        "useTls": true,
        "tlsImplicit": true,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      },
      "#jmap-loopback": {
        "name": "jmap-loopback",
        "bind": {"127.0.0.1:8446": true},
        "protocol": "http",
        "useTls": false,
        "tlsImplicit": false,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      },
      "#admin-http-loopback": {
        "name": "admin-http-loopback",
        "comment": "M25 Step 7 (pre-dispatch I1): Stalwart's default admin/management HTTP listener binds 0.0.0.0:8080 implicitly when no NetworkListener overrides it. Pinning to 127.0.0.1:8080 closes the all-interfaces leak that was equivalent to the Kratos :::4434 admin-takeover surface (Step 2 motivation). Same protocol+TLS shape as #jmap-loopback because the admin endpoint speaks HTTP (auth-redirect to /login on probe).",
        "bind": {"127.0.0.1:8080": true},
        "protocol": "http",
        "useTls": false,
        "tlsImplicit": false,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      },
      "#internal-loopback": {
        "name": "internal-loopback",
        "comment": "M25 Step 7 (pre-dispatch I1): Stalwart at v0.16.0 sometimes opens an ephemeral listener (observed as :::35181 on 10.0.3.13) for internal classifier/IPC traffic when no explicit listener owns the role. Pinning to 127.0.0.1:18181 makes the bind deterministic and reachable only on loopback. Port 18181 picked for memorability — high, unreserved, non-conflicting on every distro we ship.",
        "bind": {"127.0.0.1:18181": true},
        "protocol": "http",
        "useTls": false,
        "tlsImplicit": false,
        "socketReuseAddress": true,
        "socketReusePort": false,
        "socketNoDelay": true
      }
    }
  }
]
