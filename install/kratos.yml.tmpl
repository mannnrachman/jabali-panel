# Ory Kratos 1.3.1 Configuration Template
# Generated from: install/kratos.yml.tmpl
# Rendered by: install.sh install_kratos()
# Mustache slots below are substituted by sed during install — the post-render
# check in install_kratos() fails the install if any unexpanded slot remains.

dsn: "mysql://{{.KratosDatabaseUser}}:{{.KratosDatabasePassword}}@unix(/var/run/mysqld/mysqld.sock)/{{.KratosDatabaseName}}?parseTime=true&sql_mode=NO_ENGINE_SUBSTITUTION"

serve:
  public:
    base_url: "https://{{.PanelHostname}}:8443/.ory/"
    # M25 Step 3: public API listens on a Unix-domain socket. panel-api
    # reverse-proxies /.ory/* through this socket via the in-process
    # kratosclient.NewReverseProxyTransport (panel-api/internal/app/
    # kratos_proxy.go). Browser-facing — but the browser never touches
    # this socket directly, only the panel hostname:8443 vhost served
    # by panel-api. Same-origin design from M20 means there's no need
    # for a separate nginx upstream.
    #
    # Rollback to TCP: comment out `host` + `socket`, set
    # `host: "127.0.0.1"`, daemon-reload, restart. The kratos client +
    # reverse proxy keep working with http://127.0.0.1:4433 unchanged
    # (back-compat is intentional).
    host: "unix:/run/jabali-kratos/public.sock"
    port: 4433
    socket:
      mode: 0660
      group: "jabali-sockets"
    cors:
      enabled: true
      allowed_origins:
        - "https://{{.PanelHostname}}:8443"
      allowed_methods:
        - GET
        - POST
        - PUT
        - PATCH
        - DELETE
      allowed_headers:
        - Authorization
        - Content-Type
        - X-CSRF-Token
      exposed_headers:
        - X-CSRF-Token
      allow_credentials: true
      max_age: 120

  admin:
    # M25 Step 2: admin API listens on a Unix-domain socket instead of
    # the default all-interfaces TCP bind. Kratos v26.2.0 verification
    # gate (run 2026-04-23 against scratch MariaDB + a real Kratos
    # binary) confirmed: `host: "unix:..."` + `socket.{mode,group}` are
    # honored. The socket file ends up owned by jabali (the User= in
    # the systemd unit) and group jabali-sockets (set via `socket.group`
    # below). Mode 0660 means the panel-api process — running as jabali
    # so already in the group — can connect; nothing else on the host
    # has reach. The 127.0.0.1:4434 default is GONE (was an
    # unauthenticated admin-takeover surface on hosts without an
    # external firewall, per M25 motivation).
    #
    # Rollback to TCP: comment out `host` + `socket`, set
    # `host: "127.0.0.1"`, daemon-reload, restart. systemd drop-in
    # template shipped in plans/m25-unix-sockets-runbook.md.
    host: "unix:/run/jabali-kratos/admin.sock"
    port: 4434
    socket:
      mode: 0660
      group: "jabali-sockets"

selfservice:
  default_browser_return_url: "https://{{.PanelHostname}}:8443/dashboard"
  allowed_return_urls:
    - "https://{{.PanelHostname}}:8443"
    - "https://{{.PanelHostname}}:8443/dashboard"
    - "https://{{.PanelHostname}}:8443/login"
    - "https://{{.PanelHostname}}:8443/admin"

  methods:
    password:
      enabled: true
    profile:
      enabled: true
    link:
      enabled: false
    code:
      # Required by POST /admin/recovery/code — even though we don't
      # surface self-service code-via-email, the admin endpoint that
      # `jabali user password --link` calls 404s without this. Kratos
      # routes /admin/recovery/code through the code method handler
      # regardless of self-service exposure.
      enabled: true
      config:
        lifespan: 1h
    totp:
      enabled: true
      config:
        issuer: "Jabali Panel"
    lookup_secret:
      # Recovery codes that work as a single-use second factor when
      # the TOTP authenticator is lost. Kratos generates 12 codes per
      # regeneration; codes are hashed at rest and marked used after
      # redemption. Surfaced once in the settings flow response.
      enabled: true

  flows:
    login:
      ui_url: "https://{{.PanelHostname}}:8443/login"
      lifespan: 1h

    registration:
      enabled: false
      ui_url: "https://{{.PanelHostname}}:8443/register"
      lifespan: 1h
      after:
        password:
          hooks:
            - hook: session

    settings:
      ui_url: "https://{{.PanelHostname}}:8443/settings"
      privileged_session_max_age: 15m
      lifespan: 1h

    recovery:
      enabled: true
      ui_url: "https://{{.PanelHostname}}:8443/recovery"
      lifespan: 1h

    verification:
      enabled: true
      ui_url: "https://{{.PanelHostname}}:8443/verify"
      lifespan: 24h

    logout:
      after:
        default_browser_return_url: "https://{{.PanelHostname}}:8443/login"

identity:
  default_schema_id: default
  schemas:
    - id: default
      url: "file:///etc/jabali-panel/kratos-identity-schema.json"

# Password hashing — bcrypt is the default algorithm; cost 12 matches
# panel-api's BcryptCost so bootstrap-migrated hashes verify identically.
hashers:
  algorithm: bcrypt
  bcrypt:
    cost: 12

session:
  lifespan: 730h  # 30 days
  cookie:
    name: ory_kratos_session
    path: /
    persistent: true
    same_site: Lax
  whoami:
    # Users without TOTP/lookup_secret stay aal1 (no behaviour
    # change). Users with a second factor enrolled MUST present it
    # before whoami succeeds — without this gate Kratos would happily
    # return aal1 sessions for accounts that opted into 2FA.
    required_aal: highest_available

log:
  level: info
  format: json

secrets:
  default:
    - "{{.KratosSecretDefault}}"
  cookie:
    - "{{.KratosCookieSecret}}"
