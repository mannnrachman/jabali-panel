# AppArmor profile — jabali-agent (M40.1, ADR-0086)
#
# panel-agent binary at /usr/local/bin/jabali-agent runs as root. The
# privileged orchestrator: writes nginx vhosts, nft tables, audit
# rules, php-fpm pools, systemd unit drop-ins; shells out to nft,
# systemctl, maldet, yr, restic, certbot, etc. Profile is wider than
# panel-api (broader cap set + named exec list) but still bounded.
#
# AA 4.x (Debian 13) enforces the `unix` mediation class separately
# from `network unix`. Without explicit unix rules the daemon fails to
# dial MariaDB / dbus / other unix sockets even in complain mode.
# `unix (create, bind, listen, accept, connect, send, receive) type=stream,`
# covers every unix stream socket operation. The dgram line handles
# dbus abstract sockets.

#include <tunables/global>

profile jabali-agent /usr/local/bin/jabali-agent {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>
  # PAM — chpasswd, chage, usermod -p and similar tools call pam_authenticate.
  # Without this abstraction they get EACCES on /etc/pam.d/<tool> and fail.
  #include <abstractions/authentication>
  #include <abstractions/wutmp>

  capability chown,
  capability dac_override,
  capability dac_read_search,
  capability fowner,
  capability fsetid,
  capability kill,
  capability net_admin,
  capability net_raw,
  capability setgid,
  capability setuid,
  capability sys_admin,
  capability sys_resource,
  capability sys_ptrace,
  # mac_admin lets the UI "Flip to enforce/complain" button (which routes
  # panel-api → agent → aa-{enforce,complain}) call apparmor_parser. The
  # set_mode handler is gated by allowedProfiles.
  capability mac_admin,
  # useradd writes to audit log via libaudit.
  capability audit_write,

  network inet  stream,
  network inet6 stream,
  network unix  stream,
  network unix  dgram,
  network netlink raw,

  # ptrace read — `systemctl status` interrogates /proc/<pid>/attr under
  # unconfined processes; agent inherits enforce profile so read is denied
  # without this rule (observed: status tile dead on testserver 2026-05-10).
  ptrace (read) peer=unconfined,
  # signal HUP — nginx reload: agent sends SIGHUP to master process which
  # runs unconfined (nginx not profiled).
  signal (send) set=(hup) peer=unconfined,

  # AA 4.x unix mediation — stream sockets (MariaDB, agent wire, dbus, systemd).
  unix (create, bind, listen, accept, connect, send, receive) type=stream,
  # AA 4.x: complain mode still enforces unix peer-label checks. Explicit
  # peer=(label=unconfined) allows connecting to MariaDB and other
  # unconfined unix-socket daemons.
  unix (connect, send, receive) type=stream peer=(label=unconfined),
  # dgram — dbus abstract-namespace sockets (\0/tmp/dbus-*) and similar.
  unix (create, bind, send, receive) type=dgram,

  /usr/local/bin/jabali-agent mr,
  /etc/jabali/                 r,
  /etc/jabali/**               rw,
  /etc/jabali-panel/           r,
  /etc/jabali-panel/**         r,
  # DKIM private keys are written here by domain_email_enable.go / dkim_rotate.
  /etc/jabali-panel/dkim/      rw,
  /etc/jabali-panel/dkim/**    rw,
  # PHP-FPM per-user pool configs written by reconciler.
  /etc/jabali-panel/fpm/       rw,
  /etc/jabali-panel/fpm/**     rw,
  # Per-user PHP version selection written by user provisioning.
  /etc/jabali-panel/user-phpver/   rw,
  /etc/jabali-panel/user-phpver/** rw,
  # migration secrets written here by migration.secrets_write agent handler.
  /etc/jabali-panel/migration-secrets/   rw,
  /etc/jabali-panel/migration-secrets/** rw,
  # useradd (and usermod/userdel) read these at startup; inherited via ix.
  # /etc/.pwd.lock is the global useradd/passwd serialisation lock (flock).
  # useradd writes temp files (e.g. /etc/group.<pid>) atomically before rename:
  #   1. write /etc/group.<pid>          (w on /etc/group.*)
  #   2. link("/etc/group.<pid>",        (l on /etc/group.* — REQUIRED for hard-link)
  #           "/etc/group.lock")
  #   3. rename /etc/group → /etc/group- (rw on /etc/group-)
  #   4. rename /etc/group.<pid> → /etc/group
  # Without `l`, useradd fails with exit status 10 ("can't update group file").
  # Observed in AppArmor audit log: DENIED operation="link" name="/etc/group.lock"
  # requested_mask="l" (incident 2026-05-10).
  /etc/machine-id              r,
  /etc/login.defs              r,
  /etc/default/useradd         r,
  # useradd copies /etc/skel/* into the new home dir.
  /etc/skel/                   r,
  /etc/skel/**                 r,
  /etc/.pwd.lock               rwk,
  /etc/passwd                  rw,
  /etc/passwd.*                rwl,
  /etc/passwd-                 rw,
  /etc/passwd+                 rw,
  /etc/group                   rw,
  /etc/group.*                 rwl,
  /etc/group-                  rw,
  /etc/group+                  rw,
  /etc/shadow                  rw,
  /etc/shadow.*                rwl,
  /etc/shadow-                 rw,
  /etc/shadow+                 rw,
  # chpasswd uses /etc/nshadow as a temp file on some distros.
  /etc/nshadow                 rw,
  /etc/nshadow.*               rwl,
  /etc/gshadow                 rw,
  /etc/gshadow.*               rwl,
  /etc/gshadow-                rw,
  /etc/gshadow+                rw,
  /etc/subuid                  rw,
  /etc/subuid.*                rwl,
  /etc/subuid-                 rw,
  /etc/subuid+                 rw,
  /etc/subgid                  rw,
  /etc/subgid.*                rwl,
  /etc/subgid-                 rw,
  /etc/subgid+                 rw,
  /etc/mysql/                  r,
  /etc/mysql/**                r,
  /etc/aide/                   r,
  /etc/aide/**                 r,
  /etc/apparmor/               r,
  /etc/apparmor/**             r,
  /etc/apparmor.d/             rw,
  /etc/apparmor.d/**           rw,
  /usr/share/apparmor-features/    r,
  /usr/share/apparmor-features/**  r,
  /usr/share/iproute2/             r,
  /usr/share/iproute2/**           r,
  /usr/share/mariadb/              r,
  /usr/share/mariadb/**            r,
  /var/cache/apparmor/         rw,
  /var/cache/apparmor/**       rwk,
  /run/jabali-agent.sock       rw,
  /run/jabali-panel.sock       rw,

  # Reconciler-managed config trees (writes per ADR-0002 DB-as-truth).
  /etc/nftables.d/             rw,
  /etc/nftables.d/**           rw,
  /etc/audit/rules.d/jabali-*  rw,
  /etc/nginx/                  r,
  /etc/nginx/**                rw,
  # modules-enabled/*.conf are symlinks into modules-available; AppArmor
  # dereferences to canonical path so the target dir must also be allowed.
  /usr/share/nginx/            r,
  /usr/share/nginx/**          r,
  /etc/php/                    r,
  /etc/php/**                  rw,
  /etc/systemd/system/jabali-* rw,
  # Drop-in dirs for jabali service units (e.g. jabali-foo.service.d/).
  # The glob `jabali-*` matches files but not subdirs; explicit dir rules needed.
  /etc/systemd/system/jabali-*.service.d/  rw,
  /etc/systemd/system/jabali-*.service.d/** rw,
  /etc/systemd/system/user-*.slice.d/  rw,
  /etc/systemd/system/user-*.slice.d/** rw,
  # Per-user login session drop-ins: userSliceEnsureHandler creates
  # /etc/systemd/system/user@<uid>.service.d/ for lingering config.
  /etc/systemd/system/user@*.service.d/  rw,
  /etc/systemd/system/user@*.service.d/** rw,
  # jabali-agent writes unit files atomically via os.WriteFile to a temp path
  # then renames. systemd's atomic-write helper creates .tmp-XXXXXXXXXX in the
  # same directory. Observed DENIED operation="mknod" name=
  # "/etc/systemd/system/.tmp-3587386458" (incident 2026-05-10).
  /etc/systemd/system/         rw,
  /etc/systemd/system/.tmp-*   rw,
  # Mask symlinks for distro-shipped units (php_version_install creates
  # /etc/systemd/system/php8.4-fpm.service → /dev/null pre-apt-install
  # so the distro's php-fpm doesn't start on boot — we use jabali-fpm@.
  # Same pattern for other distro daemons we mask). Observed DENIED
  # symlink "/etc/systemd/system/php8.4-fpm.service" (incident 2026-05-12).
  /etc/systemd/system/*.service rwl,
  /etc/systemd/system/*.socket  rwl,
  /etc/systemd/system/*.timer   rwl,
  /etc/systemd/system/*.target  rwl,
  /etc/letsencrypt/            r,
  /etc/letsencrypt/**          rw,
  # Per-domain TLS certs/keys written here by cert_ensure agent handler.
  # Observed DENIED operation="mkdir" name="/etc/ssl/jabali-selfsigned/<domain>/"
  # (incident 2026-05-10) — was read-only, agent creates per-domain subdirs.
  /etc/ssl/jabali-selfsigned/   rw,
  /etc/ssl/jabali-selfsigned/** rw,
  /etc/stalwart/               r,
  /etc/stalwart/**             rw,
  /etc/powerdns/               r,
  /etc/powerdns/**             rw,
  /etc/jabali-bulwark/         r,
  /etc/jabali-bulwark/**       rw,
  /etc/crowdsec/               r,
  /etc/crowdsec/**             rw,
  /etc/modsecurity/            r,
  /etc/modsecurity/**          rw,

  /var/lib/crowdsec/data/      r,
  /var/lib/crowdsec/data/**    r,

  /var/lib/jabali-*/           rw,
  /var/lib/jabali-*/**         rwk,
  /var/log/jabali-*/           rw,
  /var/log/jabali-*/**         rwk,
  /var/log/journal/            r,
  /var/log/journal/**          r,
  /var/log/audit/              r,
  /var/log/audit/**            r,
  /var/log/nginx/              rw,
  /var/log/nginx/**            rw,
  /var/lib/aide/               rw,
  /var/lib/aide/**             rwk,
  /var/log/aide/               rw,
  /var/log/aide/**             rwk,
  /var/log/maldet/             rw,
  /var/log/maldet/**           rwk,
  /usr/local/maldetect/        r,
  /usr/local/maldetect/**      rw,

  /home/                       r,
  /home/**                     rwlk,

  /proc/                       r,
  /proc/**                     r,
  /proc/*/attr/                r,
  /proc/*/attr/current         r,
  /proc/*/attr/apparmor/current r,

  /run/                        r,
  # k (lock) permission needed for flock() on /run/jabali/ lock files.
  /run/**                      rwk,
  # /var/run is a symlink to /run on Debian, but AppArmor evaluates
  # the syscall path verbatim — go-sql-driver dials
  # /var/run/mysqld/mysqld.sock (the upstream MariaDB convention) and
  # without a matching rule the unix-socket connect returns EACCES
  # even with the profile in complain mode (AA's complain logs file
  # rule misses but enforces network mediation when no path matches).
  # Mirror the /run/** allowance under /var/run/** so both legacy and
  # canonical paths work.
  /var/run/                    r,
  /var/run/**                  rwk,
  /sys/fs/cgroup/              r,
  /sys/fs/cgroup/**            r,
  # Transparent hugepage setting read by Go runtime / MariaDB client.
  /sys/kernel/mm/transparent_hugepage/enabled r,
  # apparmor management surface (UI Flip button → set_mode handler).
  /sys/kernel/security/apparmor/    r,
  /sys/kernel/security/apparmor/**  r,
  /sys/kernel/security/apparmor/.replace  w,
  /sys/kernel/security/apparmor/.load     w,
  /sys/kernel/security/apparmor/.remove   w,
  /sys/module/apparmor/             r,
  /sys/module/apparmor/**           r,

  # Named exec list — agent shells out to these. Each ix = inherit
  # this profile (so child stays confined under jabali-agent).
  /usr/sbin/nft                ix,
  /usr/sbin/nginx              ix,
  /bin/systemctl               ix,
  /usr/bin/systemctl           ix,
  /usr/bin/loginctl            ix,
  /usr/bin/systemd-run         ix,
  /usr/sbin/sshd               ix,
  /usr/local/maldetect/maldet  ix,
  /usr/bin/yr                  ix,
  # yr (YARA-X) actually ships at /usr/local/bin/yr per install.sh:5860
  # (M33). The /usr/bin/ entry is a leftover from an earlier install
  # layout — keep both so an operator who symlinks doesn't regress.
  /usr/local/bin/yr            ix,
  # signature-base — Neo23x0/signature-base + jabali custom rules.
  # Cloned by install_malware_stack and refreshed on a timer; maldet
  # exec'd by the agent reads every .yar under here at scan time. r
  # only — agent never writes (timer-managed repo).
  /opt/jabali/signature-base/    r,
  /opt/jabali/signature-base/**  r,
  # maldet's own sig dir, populated by lmd_init + the local custom
  # symlinks. Lives outside the signature-base mirror because lmd's
  # internal scan paths (sigs/, ignore_paths, etc) are owned by lmd.
  /usr/local/maldetect/        r,
  /usr/local/maldetect/**      r,
  /usr/local/maldetect/sess/   rw,
  /usr/local/maldetect/sess/** rw,
  /usr/local/maldetect/tmp/    rw,
  /usr/local/maldetect/tmp/**  rw,
  /usr/local/maldetect/quarantine/   rw,
  /usr/local/maldetect/quarantine/** rw,
  /usr/bin/yara                ix,
  /usr/bin/clamscan            ix,
  /usr/bin/freshclam           ix,
  /usr/bin/restic              ix,
  # certbot is a Python app; inheriting the agent profile would require
  # listing all of /usr/local/lib/python3.x. Run unconfined instead.
  /usr/sbin/certbot            Ux,
  /usr/bin/certbot             Ux,
  /usr/sbin/pdnsutil           ix,
  /usr/bin/git                 ix,
  /usr/bin/quota               ix,
  /usr/sbin/quota              ix,
  /usr/bin/setquota            ix,
  /usr/sbin/setquota           ix,
  /usr/bin/quotaon             ix,
  /usr/sbin/quotaon            ix,
  /usr/bin/du                  ix,
  /bin/du                      ix,
  /usr/bin/getfacl             ix,
  /usr/bin/setfacl             ix,
  /usr/bin/usermod             ix,
  /usr/sbin/usermod            ix,
  /usr/sbin/useradd            ix,
  /usr/sbin/userdel            ix,
  /usr/sbin/groupadd           ix,
  /usr/sbin/groupdel           ix,
  /usr/sbin/groupmod           ix,
  /usr/bin/passwd              ix,
  /usr/sbin/chpasswd           ix,
  /usr/bin/chage               ix,
  /usr/bin/php*                ix,
  /usr/bin/wp                  ix,
  /usr/bin/id                  ix,
  /usr/bin/chsh                ix,
  /usr/bin/journalctl          ix,
  /usr/bin/grep                ix,
  /bin/grep                    ix,
  /usr/bin/sudo                Ux,
  # sudo loads libsudo_util.so.0 from /usr/libexec/sudo/ + reads
  # /etc/sudo.conf at start; capping the child with the agent
  # profile blocks both. Ux unconfines the sudo child so its
  # children (git, useradd, chown...) get evaluated against their
  # own profiles or the root profile, mirroring the bare-systemd
  # behavior before this AppArmor profile shipped. Inherit-mode
  # (ix) would require copying the entire /usr/libexec/sudo +
  # /etc/sudoers + ld.so + libc + libpcre2 + ... rule set inline,
  # which becomes a maintenance hazard on every libsudo bump.
  /usr/bin/getent              ix,
  /usr/bin/sftp-server         ix,
  /usr/lib/openssh/sftp-server ix,
  /usr/bin/bwrap               ix,
  /bin/sh                      ix,
  /bin/bash                    ix,
  /bin/cat                     ix,
  /usr/bin/cat                 ix,
  /bin/cp                      ix,
  /usr/bin/cp                  ix,
  /bin/mv                      ix,
  /usr/bin/mv                  ix,
  /bin/rm                      ix,
  /usr/bin/rm                  ix,
  /bin/mkdir                   ix,
  /usr/bin/mkdir               ix,
  /bin/chmod                   ix,
  /usr/bin/chmod               ix,
  /bin/chown                   ix,
  /usr/bin/chown               ix,
  /bin/ln                      ix,
  /usr/bin/ln                  ix,
  /bin/tar                     ix,
  /usr/bin/tar                 ix,
  /usr/bin/gzip                ix,
  /usr/bin/find                ix,
  /bin/find                    ix,
  /usr/bin/awk                 ix,
  /usr/bin/sed                 ix,
  /bin/sed                     ix,
  /usr/bin/curl                ix,
  /usr/bin/wget                ix,
  /usr/bin/openssl             ix,
  /usr/bin/mysql               ix,
  /usr/bin/mysqldump           ix,
  /usr/bin/mariadb             ix,
  /usr/bin/mariadb-dump        ix,
  /usr/bin/rsync               ix,
  /usr/bin/redis-cli           ix,
  # stalwart-mail binary may be installed at /opt/stalwart/stalwart with
  # /usr/local/bin/stalwart as a symlink. AppArmor resolves exec paths to
  # the canonical target, so both paths must be listed.
  /opt/stalwart/stalwart       ix,
  /usr/local/bin/jabali-*      ix,
  /usr/local/bin/kratos        ix,
  # cscli inherits jabali-agent profile via ix; Go binary self-reads its
  # own ELF (mmap) at startup — needs explicit mr in the inherited profile.
  /usr/bin/cscli               ix,
  /usr/bin/cscli               mr,
  /usr/bin/ip                  ix,
  /usr/sbin/ufw                Ux,
  /usr/bin/node                ix,
  /usr/bin/pdns_control        ix,
  /usr/bin/rec_control         ix,
  /usr/bin/redis-check-rdb     ix,
  /usr/bin/timedatectl         ix,
  /usr/bin/hostnamectl         ix,
  # apt + dpkg — php_version_install, php_ext_apply, postgres_lifecycle
  # all shell out to apt-get for package install/remove and to apt-cache
  # / dpkg-query for capability probes. Ux (unconfined exec) — apt/dpkg
  # read a wide and shifting set of paths (/etc/apt/**, /var/cache/apt/**,
  # /var/lib/dpkg/**, post-install maintainer scripts that touch arbitrary
  # locations). Inheriting jabali-agent profile via ix breaks them on the
  # first unlisted path (observed 2026-05-12: opendir /etc/apt/apt.conf.d
  # EACCES, "Error reading the CPU table"). Same pattern as certbot below.
  /usr/bin/apt                 Ux,
  /usr/bin/apt-get             Ux,
  /usr/bin/apt-cache           Ux,
  /usr/bin/apt-key             Ux,
  /usr/bin/dpkg                Ux,
  /usr/bin/dpkg-query          Ux,
  /usr/sbin/dpkg-reconfigure   Ux,
  # phpenmod / phpdismod — bash wrappers around symlink ops in
  # /etc/php/*/mods-available. ix would need every helper they call
  # (test, ln, rm, basename). Ux keeps the profile small.
  /usr/sbin/phpenmod           Ux,
  /usr/sbin/phpdismod          Ux,
  # gpasswd — used by user provisioning to add jabali to supplementary
  # groups (jabali-sockets, www-data, etc).
  /usr/bin/gpasswd             ix,
  /usr/sbin/aa-enforce         rix,
  /usr/sbin/aa-complain        rix,
  /usr/sbin/aa-status          rix,
  /usr/sbin/apparmor_parser    rix,
  /usr/sbin/pdns_recursor      ix,
  /usr/sbin/pdns_server        ix,
  # AIDE must scan the entire filesystem (its config covers /bin /etc
  # /lib /usr/bin /usr/sbin /boot /root). Inheriting the agent profile
  # via ix would deny readdir on those parent dirs and aide reports
  # all 26k+ baselined entries as "removed" (false-positive tamper).
  # Ux = unconfined exec: aide runs free of any AppArmor profile.
  /usr/bin/aide                Ux,

  # Hard denies for things the agent should never touch.
  # NOTE: do NOT deny /etc/shadow- or /etc/gshadow-. useradd / usermod /
  # passwd write the dash-suffixed backup files atomically; denying them
  # makes user provisioning fail mid-way (incident 2026-05-03: useradd
  # left /etc/passwd with a UID:GID pair whose GID had no /etc/group
  # entry, breaking systemd-run --uid=user --gid=user with status 216/
  # GROUP). The dash-suffixed files are owned root:shadow 0640 already
  # which is the real safeguard.

  # D-Bus / systemd manager. Without these the agent's `systemctl show`
  # / `systemctl restart` calls hit "Failed to connect to bus: Permission
  # denied" once the profile flips from complain to enforce — observed
  # 2026-05-07 on testserver (Server Status services tile dead, agent
  # wire returned the bus error wrapped in the services sub-call).
  # `dbus,` allows full D-Bus access; access-control boundary remains
  # the Unix socket (only the jabali group can connect to the agent),
  # so granting full D-Bus to a daemon already running as root buys no
  # additional attack surface.
  dbus,
  /run/dbus/                 r,
  /run/dbus/**               rw,
  /run/systemd/              r,
  /run/systemd/**            rw,
}
