# Jabali PHP Defense -- base rules (M41, ADR-0088).
#
# Snuffleupagus v0.13 grammar. Every .drop() ban is converted to
# .drop().simulation() by the renderer when mode=simulation; in enforce
# the .drop() runs as-is.
#
# IMPORTANT: ASCII-only. Snuffleupagus's lexer silently swallows
# subsequent rules when it hits non-ASCII (em-dashes, smart quotes).

# Log to syslog so the agent's journalctl --identifier snuffleupagus
# tail picks every incident up.
sp.log_media("syslog");

# Harden the PRNG (mt_rand seeding).
sp.harden_random.enable();

# unserialize() POP-chain protection. HMAC-pins serialized session state.
sp.unserialize_hmac.enable();

# Cookie hardening: SameSite=lax on the session cookie.
sp.cookie.name("PHPSESSID").samesite("lax");

# XXE protection: disable libxml entity expansion when ext/xml is loaded.
@condition extension_loaded("xml");
sp.xxe_protection.enable();
@end_condition;

# --- Function-execution lockdown ---
# OS command exec. CMS overlays add per-call-site allowlists via
# .filename(...) clauses where legitimate.
sp.disable_function.function("system").drop();
sp.disable_function.function("exec").drop();
sp.disable_function.function("shell_exec").drop();
sp.disable_function.function("passthru").drop();
sp.disable_function.function("popen").drop();
sp.disable_function.function("proc_open").drop();
sp.disable_function.function("pcntl_exec").drop();

# eval-by-string vector.
sp.disable_function.function("assert").drop();

# Info-leak builtins. Never legitimate in tenant code.
sp.disable_function.function("show_source").drop();
sp.disable_function.function("highlight_file").drop();
sp.disable_function.function("phpinfo").drop();

# Runtime extension load. Pinned extension dir already controlled by us.
sp.disable_function.function("dl").drop();

# putenv LD_*/PATH/GCONV_*: privilege-escalation primitive when SUID
# binaries are reachable.
sp.disable_function.function("putenv").param("assignment").value_r("LD_").drop();
sp.disable_function.function("putenv").param("assignment").value("PATH").drop();
sp.disable_function.function("putenv").param("assignment").value_r("GCONV_").drop();

# --- Stream wrapper allowlist ---
# Permit only the wrappers tenants legitimately need; phar:// (POP gadget
# vector) + expect:// (RCE) and ftp:// + glob:// stay out.
sp.wrappers_whitelist.list("file,php,http,https,data");

# NOTE: sp.readonly_exec.enable() is intentionally NOT shipped. It
# blocks ANY writable .php from executing, which kills every CMS
# (WordPress wp-admin/, Drupal modules/, plugin/theme installers all
# write .php under tenant-owned paths). Webshell-write prevention is
# handled by sp.disable_function.function("file_put_contents")
# .param("filename").value_r("\\.php$").drop() instead -- block the
# WRITE, not the EXECUTION.
sp.disable_function.function("file_put_contents").param("filename").value_r("\\.php$").drop();
