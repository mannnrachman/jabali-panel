# Bulwark webmail runtime config (M6 Step 8).
#
# Rendered by install.sh into /etc/jabali-panel/bulwark.env (mode 0640,
# owner jabali-webmail:jabali-webmail). The jabali-webmail.service unit
# loads this file via EnvironmentFile=- (optional) so the service starts
# cleanly even when rendering hasn't happened yet on a fresh install.
#
# All values here are runtime-only — no Bulwark rebuild is required when
# this file changes. A `systemctl restart jabali-webmail` picks up edits.

# Listener: loopback-only, the per-domain nginx vhost fronts it via TLS.
HOSTNAME=127.0.0.1
PORT=3000
NODE_ENV=production

# JMAP endpoint: Bulwark's browser bundle hits this from the user's
# machine, so it must be a public URL. Per-domain `mail.<domain>` is
# preferred (nginx /jmap is proxied to Stalwart on 127.0.0.1:8446 in
# the webmail vhost template). We advertise the server-level hostname
# as the default, but the browser-side Session call uses the
# same-origin `/jmap` path anyway thanks to the nginx vhost.
JMAP_SERVER_URL=https://${JABALI_SERVER_HOSTNAME}

# Bulwark 1.7.x added a security gate to /api/auth/session: incoming
# `serverUrl` must match `JMAP_SERVER_URL` (single trusted value) or
# appear in the admin-configured `jmapServers` list, otherwise the
# handler returns HTTP 500 `{"error":"JMAP server not configured"}`.
# The SSO bridge (panel-api webmail_sso.go) sends the per-tenant
# `https://mail.<tenant>` as serverUrl, which never matches the
# server-level JMAP_SERVER_URL — every webmail SSO attempt hits the
# gate and the user sees "webmail login failed (status 500)" before
# they ever see Bulwark.
#
# ALLOW_CUSTOM_JMAP_ENDPOINT=true relaxes the gate to "any public
# https:// URL that resolves" (Bulwark still runs isPublicHttpUrl).
# Safe in this deployment because:
#   - The SSO bridge synthesises serverUrl from the panel's own
#     domains table (panel-api/internal/api/webmail_sso.go), not
#     user input — the value can't be attacker-controlled.
#   - Manual logins via /login also use the SPA-provided serverUrl;
#     the SPA only fills it from /api/config (after nginx rewrite to
#     the requested $host), again not user input.
ALLOW_CUSTOM_JMAP_ENDPOINT=true

# Stalwart admin API — Bulwark uses this for password-change flows
# (user-initiated; Bulwark → Stalwart admin → mailboxes.password_hash
# update via SqlDirectory). Loopback, no TLS needed.
STALWART_FEATURES=true
STALWART_API_URL=http://127.0.0.1:8446

# TLS: bulwark fetches `${serverUrl}/.well-known/jmap` server-side
# during /api/auth/session to validate creds. ${serverUrl} is the
# per-domain `https://mail.<domain>`, which on dev/test installs is
# served by a per-domain self-signed cert (each domain its own root —
# see panel-agent/internal/commands/ssl_self_sign.go) that Node's
# default CA bundle won't trust. Without an override the handshake
# crashes with "self signed certificate" → bulwark returns non-200 →
# panel-api surfaces "webmail login failed (status 502)" — the
# recurring SSO regression.
#
# Setting NODE_TLS_REJECT_UNAUTHORIZED=0 turns off cert verification
# for ALL outbound HTTPS bulwark makes. The trade-off is acceptable
# because:
#
#   - bulwark's only outbound HTTPS target is the JMAP server it was
#     paired with (per JMAP_SERVER_URL above); it does not call
#     external HTTPS APIs from the box.
#   - mail flow itself (SMTP from Stalwart) does NOT pass through
#     bulwark, so this setting does not weaken mail-server TLS
#     verification.
#   - LE-issued certs would also be accepted (they're already in
#     Node's bundle); only the self-signed fallback specifically needs
#     this gate.
#
# If bulwark is ever scoped to call external HTTPS APIs, replace this
# with NODE_EXTRA_CA_CERTS pointing at a concatenated bundle of every
# /etc/ssl/jabali-selfsigned/*/cert.pem and revisit.
NODE_TLS_REJECT_UNAUTHORIZED=0

# Session secret (cookie signing key). Rotating this key invalidates
# every existing Bulwark session; generated once by install.sh, read
# from the file at boot so the env file itself never carries the
# secret in plaintext.
SESSION_SECRET_FILE=/etc/jabali-panel/bulwark-session.key

# Settings sync: stores per-user preferences (sort order, folder
# labels) in the local data dir so users see the same state across
# browsers. No network side-effects.
SETTINGS_SYNC_ENABLED=true
SETTINGS_DATA_DIR=/var/lib/jabali-webmail/settings

# Logging: structured JSON so journald's `-o json` aggregation picks
# up each Bulwark line as a first-class event.
LOG_FORMAT=json
LOG_LEVEL=info

# Branding: match the panel's display name so the tenant-facing
# webmail feels native.
APP_NAME=Jabali Mail
LOGIN_COMPANY_NAME=${JABALI_SERVER_HOSTNAME}
