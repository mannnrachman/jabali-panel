# Ory Kratos 1.3.1 Configuration Template
# Generated from: install/kratos.yml.tmpl
# Rendered by: install.sh install_kratos()
# Mustache slots below are substituted by sed during install — the post-render
# check in install_kratos() fails the install if any unexpanded slot remains.

dsn: "mysql://{{.KratosDatabaseUser}}:{{.KratosDatabasePassword}}@tcp(127.0.0.1:3306)/{{.KratosDatabaseName}}?parseTime=true&sql_mode=NO_ENGINE_SUBSTITUTION"

serve:
  public:
    base_url: "https://{{.PanelHostname}}/.ory/"
    port: 4433
    cors:
      enabled: true
      allowed_origins:
        - "https://{{.PanelHostname}}"
      allowed_methods:
        - GET
        - POST
        - PUT
        - PATCH
        - DELETE
      allowed_headers:
        - Authorization
        - Content-Type
        - X-CSRF-Token
      expose_headers:
        - X-CSRF-Token
      credentials: true
      max_age: 120

  admin:
    base_url: "http://127.0.0.1:4434"
    port: 4434

selfservice:
  default_browser_return_url: "https://{{.PanelHostname}}/dashboard"
  allowed_return_urls:
    - "https://{{.PanelHostname}}"
    - "https://{{.PanelHostname}}/dashboard"
    - "https://{{.PanelHostname}}/login"
    - "https://{{.PanelHostname}}/admin"

  methods:
    password:
      enabled: true
    profile:
      enabled: true
    link:
      enabled: false
    code:
      enabled: false
    totp:
      enabled: true
      config:
        issuer_name: "Jabali Panel"

  flows:
    login:
      ui_url: "https://{{.PanelHostname}}/login"
      lifespan: 1h

    registration:
      enabled: false
      ui_url: "https://{{.PanelHostname}}/register"
      lifespan: 1h
      after:
        password:
          hooks:
            - hook: session

    settings:
      ui_url: "https://{{.PanelHostname}}/settings"
      privileged_session_max_age: 15m
      lifespan: 1h

    recovery:
      enabled: true
      ui_url: "https://{{.PanelHostname}}/recovery"
      lifespan: 1h

    verification:
      enabled: true
      ui_url: "https://{{.PanelHostname}}/verify"
      lifespan: 24h

    logout:
      after:
        default_browser_return_url: "https://{{.PanelHostname}}/login"

identity:
  default_schema_id: default
  schemas:
    - id: default
      url: "file:///etc/jabali-panel/kratos-identity-schema.json"

hashers:
  bcrypt:
    enabled: true
    cost: 12
  argon2:
    enabled: false

session:
  lifespan: 730h  # 30 days
  cookie:
    name: ory_kratos_session
    domain: ""
    path: /
    persistent: true
    http_only: true
    same_site: Lax
    secure: true

  upstream:
    check_session_url: http://127.0.0.1:4434/sessions/check

log:
  level: info
  format: json

secrets:
  default:
    - "{{.KratosSecretDefault}}"
  cookie:
    - "{{.KratosCookieSecret}}"

oauth2:
  client_id: "{{.KratosClientID}}"
  client_secret: "{{.KratosClientSecret}}"
  provider: null

profiling: disable
