[Unit]
Description=Run jabali-migration-secrets-reap.service daily at 04:30
Documentation=https://git.linux-hosting.co.il/shukivaknin/jabali2/src/branch/main/docs/adr/0094-migration-importers.md

[Timer]
OnCalendar=*-*-* 04:30:00
RandomizedDelaySec=15min
Persistent=true
Unit=jabali-migration-secrets-reap.service

[Install]
WantedBy=timers.target
