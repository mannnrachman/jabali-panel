# AppArmor profile — jabali-agent (M40, ADR-0086)
#
# panel-agent binary at /usr/local/bin/jabali-agent runs as root. The
# privileged orchestrator: writes nginx vhosts, nft tables, audit
# rules, php-fpm pools, systemd unit drop-ins; shells out to nft,
# systemctl, maldet, yr, restic, certbot, etc. Profile is wider than
# panel-api (broader cap set + named exec list) but still bounded.

#include <tunables/global>

profile jabali-agent /usr/local/bin/jabali-agent {
  #include <abstractions/base>
  #include <abstractions/nameservice>
  #include <abstractions/openssl>

  capability chown,
  capability dac_override,
  capability dac_read_search,
  capability fowner,
  capability fsetid,
  capability kill,
  capability net_admin,
  capability net_raw,
  capability setgid,
  capability setuid,
  capability sys_admin,
  capability sys_resource,
  capability sys_ptrace,

  network inet  stream,
  network inet6 stream,
  network unix  stream,
  network unix  dgram,
  network netlink raw,

  /usr/local/bin/jabali-agent mr,
  /etc/jabali/                 r,
  /etc/jabali/**               rw,
  /run/jabali-agent.sock       rw,
  /run/jabali-panel.sock       rw,

  # Reconciler-managed config trees (writes per ADR-0002 DB-as-truth).
  /etc/nftables.d/jabali-*     rw,
  /etc/audit/rules.d/jabali-*  rw,
  /etc/nginx/                  r,
  /etc/nginx/**                rw,
  /etc/php/                    r,
  /etc/php/**                  rw,
  /etc/systemd/system/jabali-* rw,
  /etc/systemd/system/user-*.slice.d/  rw,
  /etc/systemd/system/user-*.slice.d/** rw,
  /etc/letsencrypt/            r,
  /etc/letsencrypt/**          rw,
  /etc/stalwart/               r,
  /etc/stalwart/**             rw,
  /etc/powerdns/               r,
  /etc/powerdns/**             rw,
  /etc/jabali-bulwark/         r,
  /etc/jabali-bulwark/**       rw,
  /etc/crowdsec/               r,
  /etc/crowdsec/**             rw,
  /etc/modsecurity/            r,
  /etc/modsecurity/**          rw,

  /var/lib/jabali-*/           rw,
  /var/lib/jabali-*/**         rwk,
  /var/log/jabali-*/           rw,
  /var/log/jabali-*/**         rwk,
  /var/log/maldet/             rw,
  /var/log/maldet/**           rwk,
  /usr/local/maldetect/        r,
  /usr/local/maldetect/**      rw,

  /home/                       r,
  /home/**                     rwlk,

  /proc/                       r,
  /proc/**                     r,

  /run/                        r,
  /run/**                      rw,
  /sys/fs/cgroup/              r,
  /sys/fs/cgroup/**            r,

  # Named exec list — agent shells out to these. Each ix = inherit
  # this profile (so child stays confined under jabali-agent).
  /usr/sbin/nft                ix,
  /usr/sbin/nginx              ix,
  /bin/systemctl               ix,
  /usr/bin/systemctl           ix,
  /usr/bin/systemd-run         ix,
  /usr/sbin/sshd               ix,
  /usr/local/maldetect/maldet  ix,
  /usr/bin/yr                  ix,
  /usr/bin/yara                ix,
  /usr/bin/clamscan            ix,
  /usr/bin/freshclam           ix,
  /usr/bin/restic              ix,
  /usr/sbin/certbot            ix,
  /usr/bin/certbot             ix,
  /usr/sbin/pdnsutil           ix,
  /usr/bin/git                 ix,
  /usr/bin/setquota            ix,
  /usr/sbin/setquota           ix,
  /usr/bin/quotaon             ix,
  /usr/sbin/quotaon            ix,
  /usr/bin/getfacl             ix,
  /usr/bin/setfacl             ix,
  /usr/bin/usermod             ix,
  /usr/sbin/usermod            ix,
  /usr/sbin/useradd            ix,
  /usr/sbin/userdel            ix,
  /usr/sbin/groupadd           ix,
  /usr/sbin/groupdel           ix,
  /usr/sbin/groupmod           ix,
  /usr/bin/passwd              ix,
  /usr/bin/chage               ix,
  /usr/bin/php*                ix,
  /usr/bin/wp                  ix,
  /usr/bin/sudo                ix,
  /usr/bin/getent              ix,
  /usr/bin/sftp-server         ix,
  /usr/lib/openssh/sftp-server ix,
  /usr/bin/bwrap               ix,
  /bin/sh                      ix,
  /bin/bash                    ix,
  /bin/cat                     ix,
  /usr/bin/cat                 ix,
  /bin/cp                      ix,
  /usr/bin/cp                  ix,
  /bin/mv                      ix,
  /usr/bin/mv                  ix,
  /bin/rm                      ix,
  /usr/bin/rm                  ix,
  /bin/mkdir                   ix,
  /usr/bin/mkdir               ix,
  /bin/chmod                   ix,
  /usr/bin/chmod               ix,
  /bin/chown                   ix,
  /usr/bin/chown               ix,
  /bin/ln                      ix,
  /usr/bin/ln                  ix,
  /bin/tar                     ix,
  /usr/bin/tar                 ix,
  /usr/bin/gzip                ix,
  /usr/bin/find                ix,
  /bin/find                    ix,
  /usr/bin/awk                 ix,
  /usr/bin/sed                 ix,
  /bin/sed                     ix,
  /usr/bin/curl                ix,
  /usr/bin/wget                ix,
  /usr/bin/openssl             ix,
  /usr/bin/mysql               ix,
  /usr/bin/mysqldump           ix,
  /usr/bin/mariadb             ix,
  /usr/bin/mariadb-dump        ix,
  /usr/bin/redis-cli           ix,
  /usr/local/bin/jabali-*      ix,
  /usr/local/bin/kratos        ix,
  /usr/bin/cscli               ix,
  /usr/bin/ip                  ix,
  /usr/bin/node                ix,
  /usr/bin/pdns_control        ix,
  /usr/bin/rec_control         ix,
  /usr/bin/redis-check-rdb     ix,
  /usr/bin/timedatectl         ix,
  /usr/sbin/aa-enforce         ix,
  /usr/sbin/aa-status          ix,
  /usr/sbin/apparmor_parser    ix,
  /usr/sbin/pdns_recursor      ix,
  /usr/sbin/pdns_server        ix,

  # Hard denies for things the agent should never touch.
  deny /etc/shadow- rwklx,
  deny /etc/gshadow- rwklx,
}
