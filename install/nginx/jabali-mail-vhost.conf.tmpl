# Per-domain webmail vhost (M6 Step 8).
#
# Rendered by the panel-agent's webmail.vhost_apply command, which
# substitutes ${DOMAIN}, ${SSL_CERT_PATH}, ${SSL_KEY_PATH} and writes
# the result to /etc/nginx/sites-available/${DOMAIN}-mail.conf, then
# symlinks sites-enabled/${DOMAIN}-mail.conf -> there.
#
# SSL note: v1 reuses the main domain's cert at
# /etc/letsencrypt/live/${DOMAIN}/fullchain.pem. That cert may not list
# mail.${DOMAIN} as a SAN; browsers will warn until a separate cert is
# issued (M6.1 follow-on). Self-signed fallback matches the M5 pattern
# for domains where ACME hasn't completed yet.

server {
  listen 443 ssl;
  http2 on;
  server_name mail.${DOMAIN};

  ssl_certificate ${SSL_CERT_PATH};
  ssl_certificate_key ${SSL_KEY_PATH};

  # Bulwark webmail (Next.js standalone on 127.0.0.1:3000). Proxy /
  # catches everything not explicitly routed below. WebSocket upgrade
  # is needed for JMAP push; long read timeout keeps idle polls alive.
  # Bulwark (Next.js) location. IMPORTANT: we intentionally DO NOT
  # send X-Forwarded-Proto to this upstream.
  #
  # Next.js's middleware-rewrite internal proxy (next/dist/server/lib/
  # router-utils/proxy-request.js) honours X-Forwarded-Proto when
  # constructing the rewrite target URL. With `X-Forwarded-Proto: https`
  # and a same-process rewrite (e.g. next-intl `/` → `/en`), the target
  # becomes `https://127.0.0.1:3000/en` — but Bulwark listens on plain
  # HTTP, so the internal proxy gets a TLS handshake error and returns
  # 500. Omitting the header keeps the rewrite target as `http://…`,
  # which Next.js handles correctly. Users still see HTTPS (nginx
  # terminates TLS); the only cost is Bulwark not setting the Secure
  # flag on its own cookies — acceptable since mail.<domain> never
  # serves HTTP-plaintext thanks to the 80→443 redirect below.
  location / {
    proxy_pass http://127.0.0.1:3000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
  }

  # Stalwart JMAP + admin API — everything the browser needs to talk
  # to the mailserver. Routed through Stalwart's single loopback HTTP
  # listener on 127.0.0.1:8446.
  location /jmap {
    proxy_pass http://127.0.0.1:8446;
    proxy_set_header Host $host;
    proxy_http_version 1.1;
    proxy_read_timeout 3600s;
  }

  location /.well-known/jmap {
    proxy_pass http://127.0.0.1:8446;
    proxy_set_header Host $host;
  }

  # NOTE: /api/* is deliberately NOT proxied to Stalwart. Bulwark owns
  # every /api/* path (its own /api/auth/session, /api/health, etc.)
  # and proxies Stalwart admin calls internally via STALWART_API_URL=
  # http://127.0.0.1:8446 set in bulwark.env. Routing /api → 8446 at
  # the nginx layer hijacks Bulwark's own endpoints and breaks login
  # (the POST body is Next.js JSON, Stalwart rejects it).

  # Block access to autodiscover helper paths so a misconfigured client
  # doesn't leak probes to Bulwark. Stalwart serves its own JMAP
  # discovery at /.well-known/jmap above.
  # Webmail SSO landing (M6 Step 8 Phase B). panel-api owns
  # /sso/webmail and sets the Bulwark session cookie on the response so
  # the 303 redirect lands the user logged in. We proxy through here
  # (rather than redirecting to the panel hostname) because the cookie
  # has to be set under mail.<domain>.
  #
  # M25 Step 4: panel-api now listens on a Unix socket. The
  # `jabali_panel_api` upstream is declared once in
  # /etc/nginx/sites-available/jabali-panel.conf (Form D — same upstream
  # name reused across server blocks). proxy_ssl_verify is gone because
  # there's no TLS hop here anymore — nginx does the only TLS termination.
  location = /sso/webmail {
    proxy_pass http://jabali_panel_api/sso/webmail;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_http_version 1.1;
  }

  location = /autodiscover/autodiscover.xml { return 404; }
  location = /Autodiscover/Autodiscover.xml { return 404; }
}

# HTTP → HTTPS redirect for mail.<domain>.
server {
  listen 80;
  server_name mail.${DOMAIN};
  return 301 https://$host$request_uri;
}
