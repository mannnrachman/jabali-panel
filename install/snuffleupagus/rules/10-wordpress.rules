# Jabali Snuffleupagus -- WordPress overlay (M41, ADR-0088).
#
# Layered above 00-base.rules. Targets known-abused WP admin endpoints.

# Plugin-RCE pattern: include $_GET['file'] inside wp-content/plugins/.
# Block remote schemes resolved through include/require.
sp.disable_function.function("include").filename_r(".*/wp-content/plugins/.*").param("file").value_r(".*://.*").drop();
sp.disable_function.function("require").filename_r(".*/wp-content/plugins/.*").param("file").value_r(".*://.*").drop();

# wp-config.php integrity: tenant PHP must never write wp-config.php.
sp.disable_function.function("file_put_contents").filename_r("/wp-config\\.php$").drop();
sp.disable_function.function("fwrite").filename_r("/wp-config\\.php$").drop();
