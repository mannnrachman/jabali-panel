# Jabali Snuffleupagus -- Joomla overlay (M41, ADR-0088).

# JEXEC guard: legitimate Joomla files start with `defined('_JEXEC')
# or die();`. Tenant PHP that bypasses this is suspicious.

# Block writes to /administrator/cache from PHP. Cache-poisoning RCE
# vector exploited in Joomla 4.x/5.x advisories.
sp.disable_function.function("file_put_contents").filename_r("/administrator/cache/").drop();
sp.disable_function.function("fwrite").filename_r("/administrator/cache/").drop();

# Language string includes: Joomla loads .ini files with parse_ini_file.
# Block parse_ini_file on /tmp paths where attacker-controlled.
sp.disable_function.function("parse_ini_file").filename_r("^/tmp/").drop();
