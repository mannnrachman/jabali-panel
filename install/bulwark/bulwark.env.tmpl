# Bulwark webmail runtime config (M6 Step 8).
#
# Rendered by install.sh into /etc/jabali-panel/bulwark.env (mode 0640,
# owner jabali-webmail:jabali-webmail). The jabali-webmail.service unit
# loads this file via EnvironmentFile=- (optional) so the service starts
# cleanly even when rendering hasn't happened yet on a fresh install.
#
# All values here are runtime-only — no Bulwark rebuild is required when
# this file changes. A `systemctl restart jabali-webmail` picks up edits.

# Listener: loopback-only, the per-domain nginx vhost fronts it via TLS.
HOSTNAME=127.0.0.1
PORT=3000
NODE_ENV=production

# JMAP endpoint: Bulwark's browser bundle hits this from the user's
# machine, so it must be a public URL. Per-domain `mail.<domain>` is
# preferred (nginx /jmap is proxied to Stalwart on 127.0.0.1:8446 in
# the webmail vhost template). We advertise the server-level hostname
# as the default, but the browser-side Session call uses the
# same-origin `/jmap` path anyway thanks to the nginx vhost.
JMAP_SERVER_URL=https://${JABALI_SERVER_HOSTNAME}

# Stalwart admin API — Bulwark uses this for password-change flows
# (user-initiated; Bulwark → Stalwart admin → mailboxes.password_hash
# update via SqlDirectory). Loopback, no TLS needed.
STALWART_FEATURES=true
STALWART_API_URL=http://127.0.0.1:8446

# Session secret (cookie signing key). Rotating this key invalidates
# every existing Bulwark session; generated once by install.sh, read
# from the file at boot so the env file itself never carries the
# secret in plaintext.
SESSION_SECRET_FILE=/etc/jabali-panel/bulwark-session.key

# Settings sync: stores per-user preferences (sort order, folder
# labels) in the local data dir so users see the same state across
# browsers. No network side-effects.
SETTINGS_SYNC_ENABLED=true
SETTINGS_DATA_DIR=/var/lib/jabali-webmail/settings

# Logging: structured JSON so journald's `-o json` aggregation picks
# up each Bulwark line as a first-class event.
LOG_FORMAT=json
LOG_LEVEL=info

# Branding: match the panel's display name so the tenant-facing
# webmail feels native.
APP_NAME=Jabali Mail
LOGIN_COMPANY_NAME=${JABALI_SERVER_HOSTNAME}
