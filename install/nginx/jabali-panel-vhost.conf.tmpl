# Jabali Panel HTTPS vhost (M25 Step 4).
#
# Rendered by install.sh install_nginx_panel_vhost(). Substitutes:
#   ${SSL_CERT_PATH}     — path to the panel TLS certificate
#   ${SSL_KEY_PATH}      — path to the panel TLS key
#
# Until M25 Step 4, panel-api terminated TLS itself on 127.0.0.1:8443.
# The TLS-strip-and-front-with-nginx pivot moved TLS termination here so
# the panel-api process can listen on a Unix-domain socket. nginx is the
# only thing on :8443 now; everything else flows through the Form D
# upstream below.
#
# Form D (per pre-dispatch I2): named upstream + plain proxy_pass — swap
# unix↔TCP in one line without touching any proxy_pass directive. Matches
# the same pattern adopted in install/nginx/.ory-location.conf and
# install/nginx/jabali-mail-vhost.conf.tmpl.

# WebSocket upgrade map (used by /api/v1/logs/stream/* and any future
# WS endpoints in panel-api). Lives in server{} scope via a map needed
# at http{} — but nginx allows map only at http{}, so this is provided
# by /etc/nginx/nginx.conf (added by install_nginx_websocket_map()).

upstream jabali_panel_api {
  # M25 Step 4: panel-api listens on this socket (mode 0660,
  # group jabali-sockets — nginx as www-data is in that group).
  # Rollback: replace with `server 127.0.0.1:8443;` and restart nginx.
  server unix:/run/jabali-panel/api.sock;
}

server {
  listen 8443 ssl;
  listen [::]:8443 ssl;
  http2 on;
  server_name _;

  ssl_certificate     ${SSL_CERT_PATH};
  ssl_certificate_key ${SSL_KEY_PATH};
  ssl_protocols       TLSv1.2 TLSv1.3;
  ssl_ciphers         HIGH:!aNULL:!MD5;
  ssl_prefer_server_ciphers on;

  # Browser uploads: WordPress imports, file-manager uploads, etc.
  # 1G matches the file-manager UI's hard ceiling (FileManagerPage
  # rejects > 1 GB client-side). Chunked uploads (>100 MB) split into
  # 10 MB chunks each, but the single-multipart path is still in
  # range up to 1 GB. The nginx default of 1 MB would 413 anything
  # above that.
  client_max_body_size 1G;

  access_log /var/log/nginx/jabali-panel.access.log;
  error_log  /var/log/nginx/jabali-panel.error.log;

  # /.ory/* is handled by panel-api itself (in-process reverse proxy
  # to the Kratos public socket). nginx just forwards to the panel
  # upstream — no special-case for /.ory/.
  location / {
    proxy_pass http://jabali_panel_api/;
    # Use $http_host to preserve port number (mx.jabali-panel.local:8443)
    # so backend can build correct WebSocket URLs. $host strips the port.
    proxy_set_header Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-Host $http_host;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_http_version 1.1;
    # WebSocket support (logs streaming, etc.)
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
  }
}
