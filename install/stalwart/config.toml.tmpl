# Stalwart Mail Server config (Jabali M6 — skeleton written by install.sh).
#
# This is a Step 1 skeleton: listeners bound, storage pointed at RocksDB,
# DNS auto-publish disabled, JMAP admin token wired in. The SQL directory
# block is a placeholder and gets filled in Step 2 (M6 plan) once the
# exact v0.16.0 filter-query syntax is verified with `stalwart --validate`.
#
# Template mustaches are substituted by install.sh using sed. Adding a
# new placeholder here requires a matching sed line — the installer
# aborts if any mustache survives substitution.

[server]
hostname = "{{.PanelHostname}}"

# ---- TCP listeners ---------------------------------------------------
# Bind loopback-only for JMAP + management API (nginx proxies from
# https://mail.<domain>/ on behalf of browsers + Bulwark).
# Bind external for SMTP/IMAP so mail clients and other MTAs reach us.

[server.listener.jmap]
bind = ["127.0.0.1:8446"]
protocol = "jmap"
tls.implicit = false

[server.listener.smtp]
bind = ["0.0.0.0:25"]
protocol = "smtp"
tls.implicit = false

[server.listener.submissions]
bind = ["0.0.0.0:465"]
protocol = "smtp"
tls.implicit = true

[server.listener.submission]
bind = ["0.0.0.0:587"]
protocol = "smtp"
tls.implicit = false

[server.listener.imaps]
bind = ["0.0.0.0:993"]
protocol = "imap"
tls.implicit = true

# ---- TLS -------------------------------------------------------------
# Reuse the panel's existing certbot plumbing (ADR-0041 decision 3 +
# plan §1 version pins). Stalwart's own ACME client is disabled.
# Per-domain certs are resolved by SNI at bind time from
# /etc/letsencrypt/live/<domain>/. The Step 5 reconciler ensures mail.<domain>
# is in the cert's SAN list.

[certificate."default"]
# Filled in Step 2 per the Stalwart v0.16.0 syntax. Skeleton reserves
# the block so the config validates as structurally complete.
cert = "file:///etc/letsencrypt/live/{{.PanelHostname}}/fullchain.pem"
private-key = "file:///etc/letsencrypt/live/{{.PanelHostname}}/privkey.pem"

# ---- Storage ---------------------------------------------------------
# Mail content (messages, FTS, bayes state, JMAP push state) lives in
# RocksDB. Directory (accounts, passwords, quotas) lives in MariaDB —
# see ADR-0042. The directory block is filled in Step 2.

[store."mail-rocksdb"]
type = "rocksdb"
path = "/var/lib/stalwart"

[storage]
data = "mail-rocksdb"
blob = "mail-rocksdb"
fts = "mail-rocksdb"
lookup = "mail-rocksdb"
# `directory` key is set once the SQL directory block lands in Step 2.

# ---- DNS -------------------------------------------------------------
# Stalwart's auto-DNS-publish feature is disabled. PowerDNS (M4) is the
# single DNS writer (ADR-0002, ADR-0041, ADR-0043). Any DNS provider
# wired in here would race the panel's reconciler.

[config.dns]
providers = []

# ---- Management / admin API -----------------------------------------
# Bulwark (jabali-webmail.service) + the panel-agent talk to this endpoint
# at http://127.0.0.1:8446/api/*. The bearer token is generated once by
# install.sh and preserved across re-runs.

[authentication.admin]
token-file = "/etc/jabali-panel/stalwart-admin.token"

