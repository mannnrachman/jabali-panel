# Jabali Panel — example environment.
#
# These ENV vars override values from config.toml. Typical use: put non-secret
# config in /etc/jabali/config.toml, put secrets here (or in a secrets manager)
# and load via systemd's EnvironmentFile.
#
# Copy to .env for local dev, or to /etc/jabali/panel.env for the systemd unit.
# NEVER commit a real secrets file — .env is git-ignored.
#
# Full reference with defaults + precedence: docs/ENV.md

# Server
PANEL_ADDR=127.0.0.1:8443
PANEL_ENV=development

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Database (Phase 3+)
# DATABASE_URL=mysql://jabali_panel:CHANGE_ME@tcp(127.0.0.1:3306)/jabali_panel?parseTime=true&charset=utf8mb4&loc=UTC

# Auth (Phase 4+)
# JWT_SECRET=$(openssl rand -hex 32)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=168h

# Agent client (panel-api -> /run/jabali/agent.sock)
# AGENT_SOCKET=/run/jabali/agent.sock
# AGENT_TIMEOUT=5s

# Agent daemon (read by the jabali-agent binary itself)
# JABALI_AGENT_SOCKET=/run/jabali/agent.sock
# JABALI_AGENT_GID=-1
# JABALI_AGENT_LOG_FORMAT=json
# JABALI_AGENT_LOG_LEVEL=info

# CORS (Phase 8+)
# CORS_ALLOWED_ORIGINS=https://panel.example.com,http://localhost:5173

# SSL / ACME
# JABALI_ACME_STAGING_ONLY=false

# SSO (phpMyAdmin — parked pending M9)
# JABALI_SSO_KEY_PATH=/etc/jabali-panel/sso.key

# Install-time knobs (install.sh only)
# JABALI_PHP_VERSIONS="8.2 8.3"
# JABALI_GITEA_TOKEN=

# Where main looks for the TOML file (default /etc/jabali/config.toml)
# JABALI_CONFIG=/etc/jabali/config.toml
