# Jabali PHP Defense -- base rules (M41, ADR-0088).
#
# Snuffleupagus v0.13 grammar. Every .drop() ban is converted to
# .drop().simulation() by the renderer when mode=simulation; in enforce
# the .drop() runs as-is.
#
# IMPORTANT: ASCII-only. Snuffleupagus's lexer silently swallows
# subsequent rules when it hits non-ASCII (em-dashes, smart quotes).

# Log to syslog so the agent's journalctl --identifier snuffleupagus
# tail picks every incident up.
sp.log_media("syslog");

# Harden the PRNG (mt_rand seeding).
sp.harden_random.enable();

# unserialize() POP-chain protection. HMAC-pins serialized session state.
sp.unserialize_hmac.enable();

# Cookie hardening: SameSite=lax on the session cookie.
sp.cookie.name("PHPSESSID").samesite("lax");

# XXE protection: disable libxml entity expansion when ext/xml is loaded.
@condition extension_loaded("xml");
sp.xxe_protection.enable();
@end_condition;

# --- Function-execution lockdown ---
# OS command exec.
sp.disable_function.function("system").drop();
sp.disable_function.function("exec").drop();
sp.disable_function.function("shell_exec").drop();
sp.disable_function.function("passthru").drop();
sp.disable_function.function("popen").drop();
sp.disable_function.function("proc_open").drop();
sp.disable_function.function("pcntl_exec").drop();

# eval-by-string vector.
sp.disable_function.function("assert").drop();

# Info-leak builtins.
sp.disable_function.function("show_source").drop();
sp.disable_function.function("highlight_file").drop();
sp.disable_function.function("phpinfo").drop();

# Runtime extension load.
sp.disable_function.function("dl").drop();

# putenv LD_*/PATH/GCONV_*: privilege-escalation primitive.
sp.disable_function.function("putenv").param("assignment").value_r("LD_").drop();
sp.disable_function.function("putenv").param("assignment").value("PATH").drop();
sp.disable_function.function("putenv").param("assignment").value_r("GCONV_").drop();

# Webshell-drop prevention: tenant PHP must not write .php files.
sp.disable_function.function("file_put_contents").param("filename").value_r("\\.php$").drop();

# --- Stream wrapper allowlist ---
sp.wrappers_whitelist.list("file,php,http,https,data");

# --- M41 enrichment: HIGH-value upstream rules (2026-05-03) ---

# eval-with-dangerous-token. Catches obfuscated payloads via
# gzinflate/base64_decode/str_rot13 wrappers that ultimately concat
# a known-bad token into the eval'd string.
sp.eval_blacklist.list("system,exec,shell_exec,passthru,proc_open,popen,pcntl_exec,assert,eval");

# Webshell upload via $_FILES. PHP 8+ param name is "destination".
sp.disable_function.function("move_uploaded_file").param("to").value_r("\\.ph").drop();
sp.disable_function.function("move_uploaded_file").param("to").value_r("\\.ht").drop();

# mail() / mb_send_mail() argv injection (CVE-2016-10033 class).
# additional_params is forwarded as-is to sendmail; '-' allows -X
# logfile-write or -C alternate-config tricks.
sp.disable_function.function("mail").param("additional_params").value_r("\\-").drop();
sp.disable_function.function("mb_send_mail").param("additional_params").value_r("\\-").drop();

# curl SSL bypass: 64=CURLOPT_SSL_VERIFYPEER, 81=CURLOPT_SSL_VERIFYHOST.
# Tenants that legitimately disable verify do it for a self-signed
# private endpoint -- use a custom CA bundle instead.
sp.disable_function.function("curl_setopt").param("option").value("64").drop();
sp.disable_function.function("curl_setopt").param("option").value("81").drop();

# curl SSRF -> LFI: file:// scheme reads local filesystem via curl.
sp.disable_function.function("curl_setopt").param("value").value_r("file://").drop();
sp.disable_function.function("curl_init").param("url").value_r("file://").drop();

# extract() on superglobal-like ($_GET/$_POST/$_REQUEST) arrays is
# unconditional auto-globals injection. flags=0 (EXTR_OVERWRITE) lets
# attacker overwrite legit local vars.
sp.disable_function.function("extract").param("array").value_r("^_").drop();
sp.disable_function.function("extract").param("flags").value("0").drop();

# include/require extension allowlist. Anything not ending in
# .php/.inc/.phtml resolves to a path-traversal LFI vector.
sp.disable_function.function("require_once").value_r("\\.(inc|phtml|php)$").allow();
sp.disable_function.function("include_once").value_r("\\.(inc|phtml|php)$").allow();
sp.disable_function.function("require").value_r("\\.(inc|phtml|php)$").allow();
sp.disable_function.function("include").value_r("\\.(inc|phtml|php)$").allow();
sp.disable_function.function("require_once").drop();
sp.disable_function.function("include_once").drop();
sp.disable_function.function("require").drop();
sp.disable_function.function("include").drop();

# Runtime ini_set lockdown. Blocks tenant code from loosening the
# server-wide hardening at request time.
sp.disable_function.function("ini_set").param("option").value("open_basedir").drop();
sp.disable_function.function("ini_set").param("option").value("assert.active").drop();
sp.disable_function.function("ini_set").param("option").value("zend.assertions").drop();
sp.disable_function.function("ini_set").param("option").value("memory_limit").drop();
sp.disable_function.function("ini_set").param("option").value("include_path").drop();
sp.disable_function.function("ini_set").param("option").value_r("error_log").drop();
sp.disable_function.function("ini_set").param("option").value_r("error_reporting").drop();
sp.disable_function.function("ini_set").param("option").value_r("display_errors").drop();
sp.disable_function.function("ini_set").param("option").value("auto_prepend_file").drop();
sp.disable_function.function("ini_set").param("option").value("auto_append_file").drop();
